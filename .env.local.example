# Supabase (Required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Resend - Email (Required for emailing PDF reports and password reset)
RESEND_API_KEY=re_xxxxxxxxxxxx
# Optional: must be on your verified Resend domain for arbitrary recipients (Gmail, etc.).
# If unset, the app defaults to Pre Delivery <noreply@<host>> from NEXT_PUBLIC_APP_URL or NEXTAUTH_URL
# (e.g. https://www.predelivery.ai → noreply@predelivery.ai). Localhost cannot auto-default.
# RESEND_FROM_EMAIL=Pre Delivery <noreply@predelivery.ai>
# Local/dev only: Resend sandbox sender — can only deliver to your Resend account email.
RESEND_FROM_EMAIL=onboarding@resend.dev

# Optional: inbox for /contact form (defaults to info@predelivery.ai)
# CONTACT_INBOX_EMAIL=info@predelivery.ai

# JWT secret for auth cookies (change in production)
JWT_SECRET=your-secret-key-change-in-production

# Admin MFA: when true, admins must complete TOTP setup/verify at login
# ENFORCE_ADMIN_MFA=true

# OAuth SSO (see docs/OAUTH_SETUP.md) — redirect: {APP_URL}/api/auth/oauth/{google|microsoft}/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# AZURE_AD_CLIENT_ID=
# AZURE_AD_CLIENT_SECRET=
# AZURE_AD_TENANT_ID=common

# Upload malware scan (VirusTotal) — set UPLOAD_MALWARE_SCAN=true to block uploads when scan fails
# VIRUSTOTAL_API_KEY=
# UPLOAD_MALWARE_SCAN=true

# AWS Sydney — private uploads (see infra/terraform)
# AWS_REGION=ap-southeast-2
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET_NAME=predelivery-uploads-dev-ACCOUNT_ID

# Application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Supabase Storage bucket name (default: inspections)
# SUPABASE_STORAGE_BUCKET=inspections

# OpenAI — voice note polish (existing) + AI damage detection on inspection photos
# OPENAI_API_KEY=sk-...
# OPENAI_VOICE_POLISH_MODEL=gpt-4o-mini
# OPENAI_VISION_DAMAGE_MODEL=gpt-4o-mini
# Set to false to disable automatic damage scan after photo upload
# OPENAI_VISION_DAMAGE_ENABLED=true
